/*
 * matmul.v - Fornax M1 
 * Multiplies Input Vector (1 x InFeatures) with Weight Matrix (InFeatures x OutFeatures)
 * 
 * Precision: INT8
 * Accumulation: INT32
 */

module matmul #(
    parameter IN_FEATURES = {{ in_features }},
    parameter OUT_FEATURES = {{ out_features }},
    parameter WEIGHT_FILE = "{{ weight_file }}"
)(
    input wire clk,
    input wire rst_n,
    input wire [7:0] in_data,
    input wire in_valid,
    output reg [31:0] out_data,
    output reg out_valid
);

    // Weight Storage
    reg [7:0] weight_rom [0:IN_FEATURES*OUT_FEATURES-1];
    initial begin
        $readmemh(WEIGHT_FILE, weight_rom);
    end

    // Control Logic
    reg [15:0] in_count;   // Tracks which input feature we are currently receiving
    reg [15:0] out_count;  // Tracks which output feature we are currently calculating
    reg [31:0] acc;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            in_count <= 0;
            out_count <= 0;
            acc <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                // Parallel-Serial MAC: For each in_data, we multiply with current weight
                // Note: This is an extremely simplified version for M1
                // We assume input is streamed IN_FEATURES times for EACH output feature?
                // No, let's assume input is streamed ONCE, and we have OUT_FEATURES accumulators?
                // For M1 simplicity, let's do: 1 input vector in, 1 output element at a time.
                
                acc <= acc + ($signed(in_data) * $signed(weight_rom[out_count * IN_FEATURES + in_count]));
                
                if (in_count == IN_FEATURES - 1) begin
                    in_count <= 0;
                    out_data <= acc + ($signed(in_data) * $signed(weight_rom[out_count * IN_FEATURES + in_count]));
                    out_valid <= 1;
                    acc <= 0;
                    if (out_count == OUT_FEATURES - 1)
                        out_count <= 0;
                    else
                        out_count <= out_count + 1;
                end else begin
                    in_count <= in_count + 1;
                end
            end
        end
    end

endmodule
